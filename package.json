{
  "name": "@multiforum/security-attachment-scan",
  "version": "0.4.0",
  "description": "Forwards uploaded file attachments to the Multiforum security-scan service (VirusTotal + static ZIP analysis).",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "plugin.json",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "bundle": "node scripts/create-bundle.mjs",
    "ci": "npm run validate:manifest && npm run test && npm run build && npm run bundle"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gennit-project/multiforum-plugin-security-attachment-scan.git"
  },
  "bugs": {
    "url": "https://github.com/gennit-project/multiforum-plugin-security-attachment-scan/issues"
  },
  "homepage": "https://github.com/gennit-project/multiforum-plugin-security-attachment-scan#readme",
  "keywords": [
    "multiforum",
    "plugin",
    "security",
    "virustotal",
    "downloads"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
